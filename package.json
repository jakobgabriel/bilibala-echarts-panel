{
  "name": "community-echarts-panel",
  "version": "2.6.0",
  "description": "ECharts panel for Grafana 11–13 (fork of bilibala-echarts-panel by @Billiballa)",
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --ignore-pattern .gitignore --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "npm run lint -- --fix",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "smoke": "scripts/smoke.sh",
    "e2e": "playwright test",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\""
  },
  "repository": "github:jakobgabriel/bilibala-echarts-panel",
  "author": "jakobgabriel",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/jakobgabriel/bilibala-echarts-panel/issues"
  },
  "dependencies": {
    "@emotion/css": "11.10.6",
    "@grafana/i18n": "12.4.2",
    "@grafana/runtime": "12.4.2",
    "@grafana/schema": "12.4.2",
    "codemirror": "^5.65.16",
    "echarts": "^4.9.0",
    "echarts-gl": "^1.1.2",
    "echarts-liquidfill": "^2.0.6",
    "echarts-wordcloud": "^1.1.3",
    "jshint": "^2.13.6",
    "lodash": "^4.17.21",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@grafana/data": "12.4.2",
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.6.1",
    "@grafana/tsconfig": "^2.0.1",
    "@grafana/ui": "12.4.2",
    "@playwright/test": "^1.57.0",
    "@stylistic/eslint-plugin-ts": "^4.4.0",
    "@swc/core": "^1.15.0",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/codemirror": "^0.0.108",
    "@types/echarts": "^4.9.22",
    "@types/jest": "^30.0.0",
    "@types/jshint": "^2.12.4",
    "@types/lodash": "^4.14.202",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsdoc": "^52.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^13.0.0",
    "identity-obj-proxy": "^3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "prettier": "^3.6.0",
    "replace-in-file-webpack-plugin": "^1.0.0",
    "sass": "^1.89.0",
    "sass-loader": "^16.0.0",
    "semver": "^7.7.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.0",
    "terser-webpack-plugin": "^5.3.0",
    "ts-node": "^10.9.0",
    "typescript": "5.9.2",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.0",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "glob": "^13.0.0",
    "test-exclude": "^8.0.0"
  },
  "packageManager": "npm@10.9.7"
}
